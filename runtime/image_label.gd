static func draw(
	image: Image,
	label: String,
	cell_origin: Vector2i,
	cell_size: Vector2i,
	label_scale: float,
) -> void:
	var scale := maxi(1, roundi(float(cell_size.y) * 0.014 * label_scale))
	var padding := maxi(2, scale)
	var available_width := maxi(1, cell_size.x - padding * 3)
	var max_characters := maxi(
		1,
		floori(float(available_width + scale) / float(6 * scale)),
	)
	var visible_label := label.substr(0, max_characters)
	var text_size := Vector2i(
		visible_label.length() * 6 * scale - scale,
		7 * scale,
	)
	var background_rect := Rect2i(
		cell_origin + Vector2i(padding, padding),
		text_size + Vector2i(padding * 2, padding * 2),
	)
	image.fill_rect(background_rect, Color(0.0, 0.0, 0.0, 0.82))
	var origin := background_rect.position + Vector2i(padding, padding)

	for glyph_index: int in range(visible_label.length()):
		var glyph: Array = GLYPHS.get(
			visible_label.substr(glyph_index, 1),
			GLYPHS["?"],
		)
		for row: int in range(glyph.size()):
			var bits := str(glyph[row])
			for column: int in range(bits.length()):
				if bits.unicode_at(column) != 49:
					continue
				image.fill_rect(
					Rect2i(
						origin + Vector2i(
							glyph_index * 6 * scale + column * scale,
							row * scale,
						),
						Vector2i(scale, scale),
					),
					Color.WHITE,
				)
